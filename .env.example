# bcbs239-lakehouse environment variables
# Copy this file to .env and fill in values. Never commit .env.

# ── Databricks Community Edition ──────────────────────────────────────
# Required ONLY for the live demo + Unity Catalog provisioning + Lakeview.
# Local PySpark tests run without these.
# Sign up free at https://community.cloud.databricks.com
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=bcbs239_lakehouse
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# ── Local development ─────────────────────────────────────────────────
# Override these only if your local Spark setup needs custom paths.
SPARK_LOCAL_DIR=/tmp/spark
PYSPARK_PYTHON=python

{
  "datasets": [
    {
      "name": "dq_scorecard_latest",
      "displayName": "Latest DQ snapshot",
      "queryLines": [
        "SELECT",
        "  source,",
        "  dimension,",
        "  score,",
        "  sample_size,",
        "  failed_count,",
        "  snapshot_ts",
        "FROM bcbs239_lakehouse.gold.fact_dq_scorecard",
        "QUALIFY ROW_NUMBER() OVER (PARTITION BY source, dimension ORDER BY snapshot_ts DESC) = 1"
      ]
    },
    {
      "name": "dq_scorecard_trend",
      "displayName": "DQ score trend",
      "queryLines": [
        "SELECT",
        "  snapshot_ts,",
        "  source,",
        "  dimension,",
        "  score",
        "FROM bcbs239_lakehouse.gold.fact_dq_scorecard",
        "ORDER BY snapshot_ts"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "BCBS 239 DQ Overview",
      "layout": [
        {
          "widget": {
            "name": "completeness_scorecard",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "dq_scorecard_latest",
                  "fields": [{ "name": "score", "expression": "AVG(score)" }],
                  "filters": [{ "field": "dimension", "value": "completeness" }]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "score",
                  "displayName": "Completeness",
                  "format": "0.0%"
                }
              }
            }
          },
          "position": { "x": 0, "y": 0, "width": 1, "height": 2 }
        },
        {
          "widget": {
            "name": "accuracy_scorecard",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "dq_scorecard_latest",
                  "fields": [{ "name": "score", "expression": "AVG(score)" }],
                  "filters": [{ "field": "dimension", "value": "accuracy" }]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "score",
                  "displayName": "Accuracy",
                  "format": "0.0%"
                }
              }
            }
          },
          "position": { "x": 1, "y": 0, "width": 1, "height": 2 }
        },
        {
          "widget": {
            "name": "timeliness_scorecard",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "dq_scorecard_latest",
                  "fields": [{ "name": "score", "expression": "AVG(score)" }],
                  "filters": [{ "field": "dimension", "value": "timeliness" }]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "score",
                  "displayName": "Timeliness",
                  "format": "0.0%"
                }
              }
            }
          },
          "position": { "x": 2, "y": 0, "width": 1, "height": 2 }
        },
        {
          "widget": {
            "name": "integrity_scorecard",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "dq_scorecard_latest",
                  "fields": [{ "name": "score", "expression": "AVG(score)" }],
                  "filters": [{ "field": "dimension", "value": "integrity" }]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "score",
                  "displayName": "Integrity",
                  "format": "0.0%"
                }
              }
            }
          },
          "position": { "x": 3, "y": 0, "width": 1, "height": 2 }
        },
        {
          "widget": {
            "name": "trend_chart",
            "queries": [
              {
                "name": "trend_query",
                "query": {
                  "datasetName": "dq_scorecard_trend",
                  "fields": [
                    { "name": "snapshot_ts", "expression": "snapshot_ts" },
                    { "name": "score", "expression": "score" },
                    { "name": "dimension", "expression": "dimension" }
                  ]
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": { "fieldName": "snapshot_ts", "displayName": "Snapshot" },
                "y": {
                  "fieldName": "score",
                  "displayName": "DQ score",
                  "scale": { "min": 0, "max": 1 }
                },
                "color": {
                  "fieldName": "dimension",
                  "displayName": "Dimension"
                }
              }
            }
          },
          "position": { "x": 0, "y": 2, "width": 4, "height": 4 }
        }
      ]
    }
  ]
}

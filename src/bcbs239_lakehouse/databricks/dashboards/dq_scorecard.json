{
  "datasets": [
    {
      "name": "dq_scorecard_latest",
      "displayName": "Latest DQ snapshot per (source, dimension)",
      "queryLines": [
        "SELECT source,",
        "       dimension,",
        "       ROUND(score, 4) AS score,",
        "       sample_size,",
        "       failed_count,",
        "       snapshot_ts",
        "FROM bcbs239_lakehouse.gold.fact_dq_scorecard",
        "QUALIFY ROW_NUMBER() OVER (PARTITION BY source, dimension ORDER BY snapshot_ts DESC) = 1"
      ]
    },
    {
      "name": "dq_scorecard_trend",
      "displayName": "DQ score trend over snapshots",
      "queryLines": [
        "SELECT snapshot_ts,",
        "       CONCAT(source, '.', dimension) AS source_dimension,",
        "       score",
        "FROM bcbs239_lakehouse.gold.fact_dq_scorecard",
        "ORDER BY snapshot_ts"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "BCBS 239 DQ Overview",
      "layout": [
        {
          "widget": {
            "name": "scorecard_table",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "dq_scorecard_latest",
                  "fields": [
                    { "name": "source", "expression": "`source`" },
                    { "name": "dimension", "expression": "`dimension`" },
                    { "name": "score", "expression": "`score`" },
                    { "name": "sample_size", "expression": "`sample_size`" },
                    { "name": "failed_count", "expression": "`failed_count`" }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 1,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  { "fieldName": "source", "displayName": "Source" },
                  { "fieldName": "dimension", "displayName": "Dimension" },
                  {
                    "fieldName": "score",
                    "displayName": "Score",
                    "numberFormat": "0.0%"
                  },
                  { "fieldName": "sample_size", "displayName": "Sample size" },
                  { "fieldName": "failed_count", "displayName": "Failed count" }
                ]
              }
            }
          },
          "position": { "x": 0, "y": 0, "width": 4, "height": 5 }
        },
        {
          "widget": {
            "name": "trend_chart",
            "queries": [
              {
                "name": "trend_query",
                "query": {
                  "datasetName": "dq_scorecard_trend",
                  "fields": [
                    { "name": "snapshot_ts", "expression": "`snapshot_ts`" },
                    { "name": "score", "expression": "`score`" },
                    {
                      "name": "source_dimension",
                      "expression": "`source_dimension`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": { "fieldName": "snapshot_ts", "displayName": "Snapshot" },
                "y": {
                  "fieldName": "score",
                  "displayName": "DQ score",
                  "scale": { "type": "quantitative", "min": 0, "max": 1 }
                },
                "color": {
                  "fieldName": "source_dimension",
                  "displayName": "Source.dimension"
                }
              }
            }
          },
          "position": { "x": 0, "y": 5, "width": 4, "height": 5 }
        }
      ]
    }
  ]
}
